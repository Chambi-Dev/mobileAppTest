<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Gestion501">
        <activity
            android:name=".dashboard.gastos.Gastos"
            android:exported="false" />
        <activity
            android:name=".dashboard.tareas.Tareas"
            android:exported="false" />
        <activity
            android:name=".dashboard.misdatos.MisDatos"
            android:exported="false" />
        <activity
            android:name=".dashboard.listatareas.ListaTareas"
            android:exported="false" />
        <activity
            android:name=".dashboard.favoritos.Favoritos"
            android:exported="false" />
        <activity
            android:name=".dashboard.empresa.Empresa"
            android:exported="false" />
        <activity
            android:name=".DashBoardActivity"
            android:exported="false" />
        <activity
            android:name=".RegistroActivity"
            android:exported="false" />
        <activity
            android:name=".PrecargadoActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
    </application>

</manifest>